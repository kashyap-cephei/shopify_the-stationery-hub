{% doc %}
  @prompt
    Create a clean minimalist footer column aligned to the left.
    
    Add a vertical list of navigation links with generous spacing.
    
    Links:
    - Retail Presence
    - About Us
    - Media
    - Blog
    - Contact Us
    - withLovefromNorthEast
    - Etsy.com
    - iTokri.com
    - amazon.in
    - flipkart.com
    
    Use black text on a white background.
    Font size around 18px.
    Medium font weight.
    Left aligned.
    Maintain consistent spacing between each item.
    No borders, icons, or background colors.
    Keep the design premium and minimal.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-nav-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-footer-nav__list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.link_spacing }}px;
  }

  .ai-footer-nav__item-{{ ai_gen_id }} {
    margin: 0;
    padding: 0;
  }

  .ai-footer-nav__link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.background_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-align: {{ block.settings.text_alignment }};
    text-decoration: none;
    display: block;
    transition: opacity 0.2s ease;
  }

  .ai-footer-nav__link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-footer-nav-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<nav class="ai-footer-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <ul class="ai-footer-nav__list-{{ ai_gen_id }}">
    {% if block.settings.link_1_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_1_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_1_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_2_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_2_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_2_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_3_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_3_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_3_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_4_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_4_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_4_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_5_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_5_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_5_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_6_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_6_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_6_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_7_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_7_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_7_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_8_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_8_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_8_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_9_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_9_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_9_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_10_text != blank %}
      <li class="ai-footer-nav__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.link_10_url }}" class="ai-footer-nav__link-{{ ai_gen_id }}">
          {{ block.settings.link_10_text }}
        </a>
      </li>
    {% endif %}
  </ul>
</nav>

