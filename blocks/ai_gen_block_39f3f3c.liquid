{% doc %}
  @prompt
    Create a clean minimalist footer column for customer support.
    
    Add a vertical list of links with equal spacing.
    
    Links:
    - Shipping and Delivery
    - Return Policy
    - Cancellation
    - Terms of Service
    - Privacy Policy
    
    Use black text on a white background.
    Font size around 18px.
    Medium font weight.
    Left aligned.
    Maintain generous vertical spacing.
    Keep the design simple, elegant, and minimal.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-support-column-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
  }

  .ai-footer-support-column__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.alignment }};
  }

  .ai-footer-support-column__list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.link_spacing }}px;
  }

  .ai-footer-support-column__link-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    text-decoration: none;
    text-align: {{ block.settings.alignment }};
    display: block;
    transition: opacity 0.2s ease;
  }

  .ai-footer-support-column__link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }
{% endstyle %}

<footer-support-column-{{ ai_gen_id }} class="ai-footer-support-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h3 class="ai-footer-support-column__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h3>
  {% endif %}

  <ul class="ai-footer-support-column__list-{{ ai_gen_id }}">
    {% if block.settings.link_1_url != blank %}
      <li>
        <a href="{{ block.settings.link_1_url }}" class="ai-footer-support-column__link-{{ ai_gen_id }}">
          {{ block.settings.link_1_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_2_url != blank %}
      <li>
        <a href="{{ block.settings.link_2_url }}" class="ai-footer-support-column__link-{{ ai_gen_id }}">
          {{ block.settings.link_2_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_3_url != blank %}
      <li>
        <a href="{{ block.settings.link_3_url }}" class="ai-footer-support-column__link-{{ ai_gen_id }}">
          {{ block.settings.link_3_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_4_url != blank %}
      <li>
        <a href="{{ block.settings.link_4_url }}" class="ai-footer-support-column__link-{{ ai_gen_id }}">
          {{ block.settings.link_4_text }}
        </a>
      </li>
    {% endif %}

    {% if block.settings.link_5_url != blank %}
      <li>
        <a href="{{ block.settings.link_5_url }}" class="ai-footer-support-column__link-{{ ai_gen_id }}">
          {{ block.settings.link_5_text }}
        </a>
      </li>
    {% endif %}
  </ul>
</footer-support-column-{{ ai_gen_id }}>

<script>
  (function() {
    class FooterSupportColumn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('footer-support-column-{{ ai_gen_id }}', FooterSupportColumn{{ ai_gen_id }});
  })();
</script>

