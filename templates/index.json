                "wrap": "pretty"
              }
            },
            "heading": {
              "type": "text",
              "settings": {
                "text": "<h2>The Kingkhap Collection</h2>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h3",
                "font": "var(--font-heading--family)",
                "line_height": "1.2",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty"
              }
            },
            "description": {
              "type": "text",
              "settings": {
                "text": "<p>The Kingkhap Collection is our tribute to the royal Ahom motif — a symbol of power, generosity, and timeless grace. Each piece tells a story of Assam's rich cultural heritage.</p>",
                "width": "fit-content",
                "max_width": "narrow",
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "line_height": "1.7",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty"
              }
            },
            "explore_btn": {
              "type": "button",
              "settings": {
                "label": "EXPLORE COLLECTION",
                "link": "shopify://collections/all",
                "style_class": "button-primary",
                "width": "fit-content",
                "width_mobile": "fit-content"
              }
            }
          },
          "block_order": [
            "collection_name",
            "heading",
            "description",
            "explore_btn"
          ]
        }
