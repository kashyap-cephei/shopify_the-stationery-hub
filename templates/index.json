    "aesthetic_buttons": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"aesthetic-buttons\" style=\"display:flex;justify-content:center;gap:24px;padding:64px 24px;flex-wrap:wrap;\"><a href=\"/collections/notebooks\" class=\"aesthetic-btn\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:16px 40px;font-family:var(--font-body--family);font-size:0.875rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;border:1px solid #2B2825;background:transparent;color:#2B2825;text-decoration:none;transition:all 0.3s;\">Notebooks</a><a href=\"/collections/accessories\" class=\"aesthetic-btn\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:16px 40px;font-family:var(--font-body--family);font-size:0.875rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;border:1px solid #2B2825;background:transparent;color:#2B2825;text-decoration:none;transition:all 0.3s;\">Accessories</a></div>",
        "section_width": "page-width",
