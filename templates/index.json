    "reviews_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"reviews-section\"><h2 style=\"font-family:var(--font-heading--family);font-size:var(--font-size--h3);font-weight:400;margin-bottom:2rem;text-align:center;\">Let customers speak for us</h2><div class=\"reviews-grid\" style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:1200px;margin:0 auto;padding:0 24px;\"><div class=\"review-card\" style=\"border:1px solid rgba(43,40,37,0.08);padding:24px;text-align:left;\"><div class=\"review-card__stars\" style=\"font-size:0.875rem;margin-bottom:8px;\">★★★★★</div><div class=\"review-card__text\" style=\"font-size:0.9375rem;line-height:1.6;opacity:0.8;margin-bottom:12px;\">Beautiful products with amazing craftsmanship. Each piece tells a unique story of North-East India's rich heritage.</div><div class=\"review-card__author\" style=\"font-size:0.8125rem;font-weight:500;opacity:0.6;\">Verified Customer</div></div><div class=\"review-card\" style=\"border:1px solid rgba(43,40,37,0.08);padding:24px;text-align:left;\"><div class=\"review-card__stars\" style=\"font-size:0.875rem;margin-bottom:8px;\">★★★★★</div><div class=\"review-card__text\" style=\"font-size:0.9375rem;line-height:1.6;opacity:0.8;margin-bottom:12px;\">The quality exceeded my expectations. Fast shipping and beautiful packaging. Will definitely order again!</div><div class=\"review-card__author\" style=\"font-size:0.8125rem;font-weight:500;opacity:0.6;\">Verified Customer</div></div><div class=\"review-card\" style=\"border:1px solid rgba(43,40,37,0.08);padding:24px;text-align:left;\"><div class=\"review-card__stars\" style=\"font-size:0.875rem;margin-bottom:8px;\">★★★★★</div><div class=\"review-card__text\" style=\"font-size:0.9375rem;line-height:1.6;opacity:0.8;margin-bottom:12px;\">A perfect gift for anyone who appreciates art and culture. The detailing on each product is remarkable.</div><div class=\"review-card__author\" style=\"font-size:0.8125rem;font-weight:500;opacity:0.6;\">Verified Customer</div></div></div></div>",
        "section_width": "full-width",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },
    "newsletter_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"newsletter-section\" style=\"padding:80px 24px;text-align:center;background:#FBF9F5;\"><h2 style=\"font-family:var(--font-heading--family);font-size:var(--font-size--h3);font-weight:400;margin-bottom:0.75rem;\">Join Our Journey</h2><p style=\"font-size:1rem;opacity:0.7;margin-bottom:1.5rem;max-width:30em;margin-left:auto;margin-right:auto;\">Sign up for the latest news and offers as we take North-East India to the world.</p><form class=\"newsletter-form\" style=\"display:flex;gap:0;max-width:420px;margin:0 auto;justify-content:center;\"><input type=\"email\" placeholder=\"Email\" style=\"flex:1;min-width:0;border:1px solid #2B2825;border-right:none;padding:12px 16px;font-family:var(--font-body--family);font-size:0.875rem;background:transparent;color:#2B2825;outline:none;\"><button type=\"submit\" style=\"background:#2B2825;color:#FBF9F5;border:1px solid #2B2825;padding:12px 24px;font-family:var(--font-body--family);font-size:0.8125rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;white-space:nowrap;\">Subscribe</button></form></div>",
        "section_width": "full-width",
        "padding-block-start": 0,
