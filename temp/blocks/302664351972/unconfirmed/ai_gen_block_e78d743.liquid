{% doc %}
  @prompt
    Create a premium full-width Hero Carousel section for a luxury stationery and lifestyle brand.
    
    Create TWO slides by default.
    
    Slide 1:
    - Background image placeholder
    - Heading: "Kingkhap Collection"
    - Button text: "Explore"
    - Button link editable
    
    Slide 2:
    - Background image placeholder
    - Heading: "Timeless Handcrafted Notebooks"
    - Button text: "Shop Now"
    - Button link editable
    
    Requirements:
    - Display one slide at a time.
    - Full-width responsive hero carousel.
    - Hero height: 700px desktop, 550px tablet, 450px mobile.
    - Background images should cover the entire section using object-fit: cover.
    - Center the heading and button both vertically and horizontally.
    - Large elegant serif heading in white.
    - White pill-shaped CTA button with black text.
    - Left and right navigation arrows.
    - Bottom pagination dots.
    - Autoplay every 5 seconds with infinite loop.
    - Smooth fade transition.
    - Mobile swipe support.
    
    Theme Editor Settings:
    Each slide should have:
    - Background Image
    - Mobile Image (optional)
    - Heading
    - Button Text
    - Button Link
    
    The merchant should be able to add, remove, edit, and reorder slides using Shopify Theme Editor blocks.
    
    Generate the section using Shopify's native blocks and settings schema. Do not hardcode any content.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 700px;
    overflow: hidden;
    display: block;
  }

  @media screen and (max-width: 989px) {
    .ai-hero-carousel-{{ ai_gen_id }} {
      height: 550px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-carousel-{{ ai_gen_id }} {
      height: 450px;
    }
  }

  .ai-hero-carousel__track-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-hero-carousel__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease-in-out, visibility 0.8s ease-in-out;
  }

  .ai-hero-carousel__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-hero-carousel__slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-hero-carousel__slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-carousel__slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-carousel__slide-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
    width: 90%;
    max-width: 800px;
  }

  .ai-hero-carousel__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.button_spacing }}px;
    letter-spacing: 0.02em;
  }

  @media screen and (max-width: 989px) {
    .ai-hero-carousel__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size_desktop }}px * 0.75);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-carousel__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size_desktop }}px * 0.6);
    }
  }

  .ai-hero-carousel__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    letter-spacing: 0.05em;
  }

  .ai-hero-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.nav_background }};
    border: none;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.nav_opacity | divided_by: 100.0 }};
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.1);
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }}--prev {
    left: {{ block.settings.nav_offset }}px;
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }}--next {
    right: {{ block.settings.nav_offset }}px;
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_size }}px * 0.5);
    height: calc({{ block.settings.nav_size }}px * 0.5);
    stroke: {{ block.settings.nav_icon_color }};
    fill: none;
    stroke-width: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-carousel__nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_size }}px * 0.8);
      height: calc({{ block.settings.nav_size }}px * 0.8);
    }

    .ai-hero-carousel__nav-{{ ai_gen_id }}--prev {
      left: calc({{ block.settings.nav_offset }}px * 0.5);
    }

    .ai-hero-carousel__nav-{{ ai_gen_id }}--next {
      right: calc({{ block.settings.nav_offset }}px * 0.5);
    }
  }

  .ai-hero-carousel__pagination-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.pagination_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: {{ block.settings.pagination_gap }}px;
    z-index: 3;
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }} {
    width: {{ block.settings.pagination_size }}px;
    height: {{ block.settings.pagination_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.pagination_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.pagination_opacity | divided_by: 100.0 }};
    padding: 0;
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pagination_active_color }};
    opacity: 1;
    transform: scale(1.3);
  }

  .ai-hero-carousel__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 2;
  }

  .ai-hero-carousel__slide-data-{{ ai_gen_id }} {
    display: none;
  }
{% endstyle %}

<hero-carousel-{{ ai_gen_id }}
  class="ai-hero-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
