    {% assign slide_data = '' %}
    {% if block.settings.slide_1_desktop_image != blank or block.settings.slide_1_heading != blank %}
      {% capture slide_1_json %}
        {
          "desktop_image": {{ block.settings.slide_1_desktop_image | image_url: width: 2000 | json }},
          "desktop_image_width": {{ block.settings.slide_1_desktop_image.width | default: 2000 | json }},
          "desktop_image_height": {{ block.settings.slide_1_desktop_image.height | default: 1000 | json }},
          "desktop_image_alt": {{ block.settings.slide_1_desktop_image.alt | escape | json }},
          "mobile_image": {{ block.settings.slide_1_mobile_image | image_url: width: 750 | json }},
          "heading": {{ block.settings.slide_1_heading | json }},
          "button_text": {{ block.settings.slide_1_button_text | json }},
          "button_link": {{ block.settings.slide_1_button_link | json }}
        }
      {% endcapture %}
      {% assign slide_data = slide_data | append: slide_1_json | append: '|||' %}
    {% endif %}

    {% if block.settings.slide_2_desktop_image != blank or block.settings.slide_2_heading != blank %}
      {% capture slide_2_json %}
        {
          "desktop_image": {{ block.settings.slide_2_desktop_image | image_url: width: 2000 | json }},
          "desktop_image_width": {{ block.settings.slide_2_desktop_image.width | default: 2000 | json }},
          "desktop_image_height": {{ block.settings.slide_2_desktop_image.height | default: 1000 | json }},
          "desktop_image_alt": {{ block.settings.slide_2_desktop_image.alt | escape | json }},
          "mobile_image": {{ block.settings.slide_2_mobile_image | image_url: width: 750 | json }},
          "heading": {{ block.settings.slide_2_heading | json }},
          "button_text": {{ block.settings.slide_2_button_text | json }},
          "button_link": {{ block.settings.slide_2_button_link | json }}
        }
      {% endcapture %}
      {% assign slide_data = slide_data | append: slide_2_json | append: '|||' %}
    {% endif %}

    {% if block.settings.slide_3_desktop_image != blank or block.settings.slide_3_heading != blank %}
      {% capture slide_3_json %}
        {
          "desktop_image": {{ block.settings.slide_3_desktop_image | image_url: width: 2000 | json }},
          "desktop_image_width": {{ block.settings.slide_3_desktop_image.width | default: 2000 | json }},
          "desktop_image_height": {{ block.settings.slide_3_desktop_image.height | default: 1000 | json }},
          "desktop_image_alt": {{ block.settings.slide_3_desktop_image.alt | escape | json }},
          "mobile_image": {{ block.settings.slide_3_mobile_image | image_url: width: 750 | json }},
          "heading": {{ block.settings.slide_3_heading | json }},
          "button_text": {{ block.settings.slide_3_button_text | json }},
          "button_link": {{ block.settings.slide_3_button_link | json }}
        }
      {% endcapture %}
      {% assign slide_data = slide_data | append: slide_3_json | append: '|||' %}
    {% endif %}

    {% if block.settings.slide_4_desktop_image != blank or block.settings.slide_4_heading != blank %}
      {% capture slide_4_json %}
        {
          "desktop_image": {{ block.settings.slide_4_desktop_image | image_url: width: 2000 | json }},
          "desktop_image_width": {{ block.settings.slide_4_desktop_image.width | default: 2000 | json }},
          "desktop_image_height": {{ block.settings.slide_4_desktop_image.height | default: 1000 | json }},
          "desktop_image_alt": {{ block.settings.slide_4_desktop_image.alt | escape | json }},
          "mobile_image": {{ block.settings.slide_4_mobile_image | image_url: width: 750 | json }},
          "heading": {{ block.settings.slide_4_heading | json }},
          "button_text": {{ block.settings.slide_4_button_text | json }},
          "button_link": {{ block.settings.slide_4_button_link | json }}
        }
      {% endcapture %}
      {% assign slide_data = slide_data | append: slide_4_json | append: '|||' %}
    {% endif %}

    {% if block.settings.slide_5_desktop_image != blank or block.settings.slide_5_heading != blank %}
      {% capture slide_5_json %}
        {
          "desktop_image": {{ block.settings.slide_5_desktop_image | image_url: width: 2000 | json }},
          "desktop_image_width": {{ block.settings.slide_5_desktop_image.width | default: 2000 | json }},
          "desktop_image_height": {{ block.settings.slide_5_desktop_image.height | default: 1000 | json }},
          "desktop_image_alt": {{ block.settings.slide_5_desktop_image.alt | escape | json }},
          "mobile_image": {{ block.settings.slide_5_mobile_image | image_url: width: 750 | json }},
          "heading": {{ block.settings.slide_5_heading | json }},
          "button_text": {{ block.settings.slide_5_button_text | json }},
          "button_link": {{ block.settings.slide_5_button_link | json }}
        }
      {% endcapture %}
      {% assign slide_data = slide_data | append: slide_5_json %}
    {% endif %}

    <div data-slides="{{ slide_data }}"></div>
  </div>

  <div class="ai-hero-carousel__track-{{ ai_gen_id }}"></div>
</hero-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.slides = [];
      }

      connectedCallback() {
        this.parseSlideData();
        this.renderSlides();
        this.setupEventListeners();
        this.setupTouchEvents();

        if (this.slides.length > 1) {
          this.autoplay = this.dataset.autoplay === 'true';
          this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

          if (this.autoplay) {
            this.startAutoplay();
          }
        }
      }

      parseSlideData() {
        const dataContainer = this.querySelector('[data-slides]');
        if (!dataContainer) return;

        const slidesString = dataContainer.dataset.slides;
        const slideParts = slidesString.split('|||').filter(part => part.trim());

        this.slides = slideParts.map(part => {
          try {
            return JSON.parse(part.trim());
          } catch (e) {
            return null;
          }
        }).filter(slide => slide !== null);
      }

      renderSlides() {
        const track = this.querySelector('.ai-hero-carousel__track-{{ ai_gen_id }}');
        if (!track) return;

        if (this.slides.length === 0) {
          track.innerHTML = `
            <div class="ai-hero-carousel__slide-{{ ai_gen_id }} active">
              <div class="ai-hero-carousel__slide-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                <div class="ai-hero-carousel__empty-state-{{ ai_gen_id }}">
                  Next, add background images and content to your slides
                </div>
              </div>
            </div>
          `;
          return;
        }

        let slidesHTML = '';
        this.slides.forEach((slide, index) => {
          const isActive = index === 0 ? 'active' : '';
          const loading = index === 0 ? 'eager' : 'lazy';

          let imageHTML = '';
          if (slide.desktop_image && slide.desktop_image !== 'null') {
            if (slide.mobile_image && slide.mobile_image !== 'null') {
              imageHTML = `
                <picture>
                  <source media="(max-width: 749px)" srcset="${slide.mobile_image}">
                  <img
                    src="${slide.desktop_image}"
                    alt="${slide.desktop_image_alt || ''}"
                    loading="${loading}"
                    width="${slide.desktop_image_width}"
                    height="${slide.desktop_image_height}"
                    class="ai-hero-carousel__slide-image-{{ ai_gen_id }}"
                  >
                </picture>
              `;
            } else {
              imageHTML = `
                <img
                  src="${slide.desktop_image}"
                  alt="${slide.desktop_image_alt || ''}"
                  loading="${loading}"
                  width="${slide.desktop_image_width}"
                  height="${slide.desktop_image_height}"
                  class="ai-hero-carousel__slide-image-{{ ai_gen_id }}"
                >
              `;
            }
          } else {
            imageHTML = `
              <div class="ai-hero-carousel__slide-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                ${index === 0 ? `
                  <div class="ai-hero-carousel__empty-state-{{ ai_gen_id }}">
                    Next, add background images to your slides
                  </div>
                ` : ''}
              </div>
            `;
          }

          const headingHTML = slide.heading ? `
            <h2 class="ai-hero-carousel__heading-{{ ai_gen_id }}">${slide.heading}</h2>
          ` : '';

          const buttonHTML = slide.button_text ? `
            <a href="${slide.button_link || '#'}" class="ai-hero-carousel__button-{{ ai_gen_id }}">
              ${slide.button_text}
            </a>
          ` : '';

          slidesHTML += `
            <div class="ai-hero-carousel__slide-{{ ai_gen_id }} ${isActive}" data-slide-index="${index}">
              ${imageHTML}
              <div class="ai-hero-carousel__slide-content-{{ ai_gen_id }}">
                ${headingHTML}
                ${buttonHTML}
              </div>
            </div>
          `;
        });

        if (this.slides.length > 1) {
          slidesHTML += `
            <button class="ai-hero-carousel__nav-{{ ai_gen_id }} ai-hero-carousel__nav-{{ ai_gen_id }}--prev" aria-label="Previous slide">
              <svg viewBox="0 0 24 24">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <button class="ai-hero-carousel__nav-{{ ai_gen_id }} ai-hero-carousel__nav-{{ ai_gen_id }}--next" aria-label="Next slide">
              <svg viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
            <div class="ai-hero-carousel__pagination-{{ ai_gen_id }}">
              ${this.slides.map((_, i) => `
                <button class="ai-hero-carousel__dot-{{ ai_gen_id }} ${i === 0 ? 'active' : ''}" data-dot-index="${i}" aria-label="Go to slide ${i + 1}"></button>
              `).join('')}
            </div>
          `;
        }

        track.innerHTML = slidesHTML;
      }

      setupEventListeners() {
        if (this.slides.length <= 1) return;

        const prevButton = this.querySelector('.ai-hero-carousel__nav-{{ ai_gen_id }}--prev');
        const nextButton = this.querySelector('.ai-hero-carousel__nav-{{ ai_gen_id }}--next');
        const dots = this.querySelectorAll('.ai-hero-carousel__dot-{{ ai_gen_id }}');

        if (prevButton) {
          prevButton.addEventListener('click', () => {
            this.goToPrevSlide();
            this.resetAutoplay();
          });
        }

        if (nextButton) {
          nextButton.addEventListener('click', () => {
            this.goToNextSlide();
            this.resetAutoplay();
          });
        }

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });
      }

      setupTouchEvents() {
        if (this.slides.length <= 1) return;

        this.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNextSlide();
          } else {
            this.goToPrevSlide();
          }
          this.resetAutoplay();
        }
      }

      goToSlide(index) {
        const slideElements = this.querySelectorAll('.ai-hero-carousel__slide-{{ ai_gen_id }}');
        const dotElements = this.querySelectorAll('.ai-hero-carousel__dot-{{ ai_gen_id }}');

        if (slideElements[this.currentSlide]) {
          slideElements[this.currentSlide].classList.remove('active');
        }
        if (dotElements[this.currentSlide]) {
          dotElements[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        if (slideElements[this.currentSlide]) {
          slideElements[this.currentSlide].classList.add('active');
        }
        if (dotElements[this.currentSlide]) {
          dotElements[this.currentSlide].classList.add('active');
        }
      }

      goToNextSlide() {
        const nextSlide = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextSlide);
      }

      goToPrevSlide() {
        const prevSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevSlide);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        if (this.autoplay) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-carousel-{{ ai_gen_id }}', HeroCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hero carousel",
  "settings": [
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Desktop size",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_spacing",
      "label": "Spacing below heading",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
