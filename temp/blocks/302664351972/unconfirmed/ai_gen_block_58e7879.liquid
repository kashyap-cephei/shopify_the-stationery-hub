    },
    {
      "type": "url",
      "id": "slide_1_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Slide 2"
    },
    {
      "type": "image_picker",
      "id": "slide_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "slide_2_heading",
      "label": "Heading",
      "default": "Discover our collection"
    },
    {
      "type": "text",
      "id": "slide_2_button_text",
      "label": "Button text",
      "default": "Explore"
    },
    {
      "type": "url",
