{% doc %}
  @prompt
    Create a premium full-width Hero Carousel section for a luxury stationery and lifestyle brand.
    
    Section Requirements:
    - Full-width responsive image slider.
    - Support multiple slides (minimum 2, unlimited preferred).
    - Each slide should have:
      - Desktop image
      - Mobile image (optional)
      - Heading
      - Button text
      - Button link
    - All content must be editable from the Shopify Theme Editor.
    
    Layout:
    - Display one slide at a time.
    - Image should cover the entire hero area using object-fit: cover.
    - Hero height:
      - Desktop: 700px
      - Tablet: 550px
      - Mobile: 450px
    
    Content Overlay:
    - Center the content both vertically and horizontally.
    - Large elegant serif heading in white (50–60px desktop).
    - White pill-shaped CTA button below the heading.
    - Button should have black text with subtle hover animation.
    - Keep sufficient spacing between heading and button.
    
    Navigation:
    - Left and right navigation arrows vertically centered.
    - Bottom center pagination dots.
    - Active dot filled, inactive dots outlined.
    - Smooth fade transition between slides (500–700ms).
    
    Slider Behaviour:
    - Autoplay every 5 seconds.
    - Infinite loop.
    - Pause autoplay when hovering over the slider.
    - Swipe support on mobile.
    - Keyboard navigation support.
    
    Theme Settings:
    Each slide should allow:
    - Hero Image
    - Mobile Image
    - Heading
    - Button Text
    - Button Link
    - Optional dark overlay opacity (0–60%)
    
    General Settings:
    - Hero height
    - Enable/Disable autoplay
    - Autoplay speed
    - Show/Hide arrows
    - Show/Hide dots
    - Content alignment (Center / Left / Right)
    - Overlay opacity
    - Text color
    - Button colors
    
    Style:
    Minimal, luxury, handcrafted, editorial, premium ecommerce aesthetic with generous white space and smooth animations.
    
    Generate this as a reusable Shopify section using native Shopify blocks so the merchant can easily add, remove, or reorder slides from the Theme Editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-carousel-slide-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height_desktop }}px;
    display: none;
    opacity: 0;
    transition: opacity {{ section.settings.transition_speed }}ms ease-in-out;
  }

  .ai-hero-carousel-slide-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-hero-carousel-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-hero-carousel-slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    pointer-events: none;
  }

  .ai-hero-carousel-slide-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: {{ section.settings.content_alignment }};
    z-index: 2;
    width: 90%;
    max-width: 800px;
  }

  .ai-hero-carousel-slide-heading-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: {{ section.settings.heading_size_desktop }}px;
    line-height: 1.2;
    color: {{ section.settings.text_color }};
    margin: 0 0 32px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .ai-hero-carousel-slide-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 48px;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-carousel-slide-button-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  @media screen and (max-width: 989px) {
    .ai-hero-carousel-slide-{{ ai_gen_id }} {
      height: {{ section.settings.hero_height_tablet }}px;
    }

    .ai-hero-carousel-slide-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_size_desktop | times: 0.7 }}px;
      margin-bottom: 24px;
    }

    .ai-hero-carousel-slide-button-{{ ai_gen_id }} {
      padding: 14px 40px;
      font-size: 14px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-carousel-slide-{{ ai_gen_id }} {
      height: {{ section.settings.hero_height_mobile }}px;
    }

    .ai-hero-carousel-slide-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_size_desktop | times: 0.5 }}px;
      margin-bottom: 20px;
    }

    .ai-hero-carousel-slide-button-{{ ai_gen_id }} {
      padding: 12px 32px;
      font-size: 13px;
    }

    .ai-hero-carousel-slide-content-{{ ai_gen_id }} {
      width: 85%;
    }
  }
{% endstyle %}

<div
  class="ai-hero-carousel-slide-{{ ai_gen_id }}"
  data-slide-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.mobile_image != blank %}
    <picture>
      <source
        media="(max-width: 749px)"
        srcset="{{ block.settings.mobile_image | image_url: width: 800 }}"
      >
      {% if block.settings.image != blank %}
        <img
          src="{{ block.settings.image | image_url: width: 2400 }}"
          alt="{{ block.settings.image.alt | escape }}"
          class="ai-hero-carousel-slide-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-hero-carousel-slide-image-{{ ai_gen_id }}" style="background-color: #f4f4f4;">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </picture>
  {% else %}
    {% if block.settings.image != blank %}
      <img
        src="{{ block.settings.image | image_url: width: 2400 }}"
        alt="{{ block.settings.image.alt | escape }}"
        class="ai-hero-carousel-slide-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-hero-carousel-slide-image-{{ ai_gen_id }}" style="background-color: #f4f4f4;">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  {% endif %}

  <div class="ai-hero-carousel-slide-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-carousel-slide-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-hero-carousel-slide-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-hero-carousel-slide-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Slide",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted with care"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 0.6,
      "step": 0.1,
      "default": 0.3
    }
  ],
  "presets": [
    {
      "name": "Slide"
    }
  ]
}
{% endschema %}
