{% doc %}
  @prompt
    Create a premium split-layout section for a luxury stationery and lifestyle brand.
    
    Layout:
    - Two-column layout.
    - Left column: 40% width.
    - Right column: 60% width.
    - Full-width section with generous white space.
    
    Left Side:
    - Solid matte black background (#0D0D0D).
    - Center a premium gold emblem/logo near the middle.
    - Below the emblem, display the collection title in an elegant serif font:
      "Kingkhap Collection"
    - Use luxurious gold typography.
    - Keep the design minimal with lots of negative space.
    - Vertically center all content.
    
    Right Side:
    - Display a large autoplay, muted, looping video instead of an image.
    - Video should cover the entire right column (object-fit: cover).
    - No controls visible.
    - Soft fade-in animation on load.
    - Rounded corners are NOT required.
    - Maintain a premium editorial look.
    
    Section Settings:
    - Left logo image should be editable.
    - Collection title editable.
    - Right video upload editable.
    - Optional mobile fallback image.
    - Button enable/disable option.
    - Background colors editable.
    
    Responsive:
    - Desktop: 40/60 split layout.
    - Tablet: 45/55.
    - Mobile: Stack vertically with the black content panel first and the video below.
    
    Style:
    Minimal, luxury, editorial, handcrafted, premium fashion & stationery aesthetic with smooth transitions and elegant typography., need to chanege panel right to left and left to right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-split-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    min-height: 100vh;
  }

  .ai-luxury-split__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 60% 40%;
    min-height: 100vh;
    width: 100%;
  }

  .ai-luxury-split__left-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.left_background_color }};
  }

  .ai-luxury-split__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1.5s ease-out 0.5s forwards;
  }

  .ai-luxury-split__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1.5s ease-out 0.5s forwards;
  }

  .ai-luxury-split__media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-luxury-split__media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-luxury-split__mobile-fallback-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-luxury-split__right-{{ ai_gen_id }} {
    background-color: {{ block.settings.right_background_color }};
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.right_padding }}px;
    position: relative;
  }

  .ai-luxury-split__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    max-width: 500px;
    width: 100%;
  }

  .ai-luxury-split__emblem-{{ ai_gen_id }} {
    width: {{ block.settings.emblem_size }}px;
    height: auto;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1s ease-out 0.3s forwards;
  }

  .ai-luxury-split__emblem-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.emblem_size }}px;
    height: {{ block.settings.emblem_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1s ease-out 0.3s forwards;
  }

  .ai-luxury-split__emblem-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-luxury-split__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: center;
    margin: 0;
    letter-spacing: {{ block.settings.title_letter_spacing }}em;
    line-height: 1.2;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1s ease-out 0.6s forwards;
  }

  .ai-luxury-split__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    text-align: center;
    margin: 0;
    letter-spacing: {{ block.settings.subtitle_letter_spacing }}em;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1s ease-out 0.9s forwards;
  }

  .ai-luxury-split__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    transition: all 0.4s ease;
    opacity: 0;
    animation: ai-luxury-fade-in-{{ ai_gen_id }} 1s ease-out 1.2s forwards;
  }

  .ai-luxury-split__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  @keyframes ai-luxury-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 989px) {
    .ai-luxury-split__container-{{ ai_gen_id }} {
      grid-template-columns: 55% 45%;
    }

    .ai-luxury-split__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-luxury-split__emblem-{{ ai_gen_id }},
    .ai-luxury-split__emblem-placeholder-{{ ai_gen_id }} {
      width: calc({{ block.settings.emblem_size }}px * 0.8);
      height: calc({{ block.settings.emblem_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-split__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ai-luxury-split__left-{{ ai_gen_id }} {
      min-height: 70vh;
      order: 2;
    }

    .ai-luxury-split__right-{{ ai_gen_id }} {
      min-height: 100vh;
      order: 1;
    }

    .ai-luxury-split__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.6);
    }

    .ai-luxury-split__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-luxury-split__emblem-{{ ai_gen_id }},
    .ai-luxury-split__emblem-placeholder-{{ ai_gen_id }} {
      width: calc({{ block.settings.emblem_size }}px * 0.6);
      height: calc({{ block.settings.emblem_size }}px * 0.6);
    }

    {% if block.settings.mobile_fallback_image != blank %}
      .ai-luxury-split__video-{{ ai_gen_id }} {
        display: none;
      }

      .ai-luxury-split__mobile-fallback-{{ ai_gen_id }} {
        display: block;
        opacity: 0;
        animation: ai-luxury-fade-in-{{ ai_gen_id }} 1.5s ease-out 0.5s forwards;
      }
    {% endif %}
  }
{% endstyle %}

<luxury-split-{{ ai_gen_id }} class="ai-luxury-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-split__container-{{ ai_gen_id }}">
    <div class="ai-luxury-split__left-{{ ai_gen_id }}">
      {% if block.settings.left_image != blank %}
        <img
          src="{{ block.settings.left_image | image_url: width: 2000 }}"
          alt="{{ block.settings.left_image.alt | escape }}"
          class="ai-luxury-split__image-{{ ai_gen_id }}"
          width="2000"
          height="auto"
          loading="lazy"
        >
      {% else %}
        <div class="ai-luxury-split__media-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.mobile_fallback_image != blank %}
        <img
          src="{{ block.settings.mobile_fallback_image | image_url: width: 1500 }}"
          alt="{{ block.settings.mobile_fallback_image.alt | escape }}"
          class="ai-luxury-split__mobile-fallback-{{ ai_gen_id }}"
          width="1500"
          height="auto"
          loading="lazy"
        >
      {% endif %}
    </div>

    <div class="ai-luxury-split__right-{{ ai_gen_id }}">
      <div class="ai-luxury-split__content-{{ ai_gen_id }}">
        {% if block.settings.emblem_image != blank %}
          <img
            src="{{ block.settings.emblem_image | image_url: width: 600 }}"
            alt="{{ block.settings.emblem_image.alt | escape }}"
            class="ai-luxury-split__emblem-{{ ai_gen_id }}"
            width="{{ block.settings.emblem_size }}"
            height="auto"
            loading="lazy"
          >
        {% else %}
          <div class="ai-luxury-split__emblem-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.collection_title != blank %}
          <h2 class="ai-luxury-split__title-{{ ai_gen_id }}">
            {{ block.settings.collection_title }}
          </h2>
        {% endif %}

        {% if block.settings.subtitle != blank %}
          <p class="ai-luxury-split__subtitle-{{ ai_gen_id }}">
            {{ block.settings.subtitle }}
          </p>
        {% endif %}

        {% if block.settings.show_button and block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-luxury-split__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</luxury-split-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxurySplit{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-luxury-split__video-{{ ai_gen_id }}');
        if (this.video) {
          this.initVideo();
        }
      }

      initVideo() {
        this.video.addEventListener('loadeddata', function() {
          this.play().catch(function() {});
        });

        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            const video = entry.target;
            if (entry.isIntersecting) {
              video.play().catch(function() {});
            } else {
              video.pause();
            }
          });
        }, { threshold: 0.5 });

        observer.observe(this.video);
      }
    }

    customElements.define('luxury-split-{{ ai_gen_id }}', LuxurySplit{{ ai_gen_id }});
  })();
</script>

