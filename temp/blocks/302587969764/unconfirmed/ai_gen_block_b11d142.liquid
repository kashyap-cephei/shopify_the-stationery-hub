{% doc %}
  @prompt
    Create a premium "Shop by Collection" section for a luxury stationery and lifestyle brand.
    
    Layout:
    - Display a section heading at the top left:
      "Shop by Collection"
    - Below the heading, display 4 collection cards in a single horizontal row.
    - Equal-width cards with 20–24px spacing.
    - Full-width section with generous left and right padding.
    - No card borders or shadows.
    
    Collection Card:
    - Large portrait image with a 4:5 aspect ratio.
    - Images should use object-fit: cover.
    - Collection name displayed below the image.
    - Left-aligned text.
    - Elegant serif heading for the section.
    - Collection title in a clean sans-serif font, medium weight.
    - No buttons, overlays, badges, or animations.
    
    Theme Settings:
    - Support multiple collection blocks.
    - Each block should include:
      - Collection image
      - Collection title
      - Collection link
    - Clicking anywhere on the card should navigate to the assigned collection.
    
    Responsive:
    - Desktop: 4 columns.
    - Tablet: 2 columns.
    - Mobile: Horizontal swipe carousel showing 1.2 cards at a time.
    
    Style:
    Minimal, premium, editorial, luxury stationery aesthetic with generous white space, clean typography, and subtle hover effect (slight image zoom only). All content should be editable through the Shopify Theme Editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shop-collections-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 40px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-shop-collections-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-shop-collections-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 40px 0;
    text-align: left;
    line-height: 1.2;
  }

  .ai-shop-collections-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-shop-collection-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
  }

  .ai-shop-collection-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 125%;
    overflow: hidden;
    background-color: #f5f5f5;
    margin-bottom: 16px;
  }

  .ai-shop-collection-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .ai-shop-collection-card-{{ ai_gen_id }}:hover .ai-shop-collection-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-shop-collection-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-shop-collection-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-shop-collection-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    text-align: left;
    line-height: 1.4;
  }

  @media screen and (max-width: 989px) {
    .ai-shop-collections-{{ ai_gen_id }} {
      padding: 50px 30px;
    }

    .ai-shop-collections-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
      margin-bottom: 30px;
    }

    .ai-shop-collections-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_spacing | times: 0.8 }}px;
    }

    .ai-shop-collection-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-shop-collections-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-shop-collections-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 24px;
    }

    .ai-shop-collections-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 16px;
      padding-bottom: 10px;
    }

    .ai-shop-collection-card-{{ ai_gen_id }} {
      flex: 0 0 83.33%;
      scroll-snap-align: start;
    }

    .ai-shop-collection-image-wrapper-{{ ai_gen_id }} {
      margin-bottom: 12px;
    }

    .ai-shop-collection-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<shop-collections-{{ ai_gen_id }} class="ai-shop-collections-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-shop-collections-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-shop-collections-heading-{{ ai_gen_id }}">
        {{ block.settings.section_heading }}
      </h2>
    {% endif %}

    <div class="ai-shop-collections-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign image_key = 'collection_image_' | append: i
          assign title_key = 'collection_title_' | append: i
          assign url_key = 'collection_url_' | append: i

          assign collection = block.settings[collection_key]
          assign custom_image = block.settings[image_key]
          assign custom_title = block.settings[title_key]
          assign custom_url = block.settings[url_key]
        %}

        {% if custom_url != blank %}
          {% assign link_url = custom_url %}
        {% elsif collection != blank %}
          {% assign link_url = collection.url %}
        {% else %}
          {% assign link_url = '#' %}
        {% endif %}

        <a 
          href="{{ link_url }}" 
          class="ai-shop-collection-card-{{ ai_gen_id }}"
          {% if collection != blank %}
            aria-label="View {{ collection.title }} collection"
          {% else %}
            aria-label="View collection"
          {% endif %}
        >
          <div class="ai-shop-collection-image-wrapper-{{ ai_gen_id }}">
            {% if custom_image != blank %}
              <img
                src="{{ custom_image | image_url: width: 800 }}"
                alt="{{ custom_image.alt | escape }}"
                loading="lazy"
                width="800"
                height="1000"
                class="ai-shop-collection-image-{{ ai_gen_id }}"
              >
            {% elsif collection != blank and collection.featured_image != blank %}
              <img
                src="{{ collection.featured_image | image_url: width: 800 }}"
                alt="{{ collection.featured_image.alt | escape }}"
                loading="lazy"
                width="800"
                height="1000"
                class="ai-shop-collection-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-shop-collection-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <h3 class="ai-shop-collection-title-{{ ai_gen_id }}">
            {% if custom_title != blank %}
              {{ custom_title }}
            {% elsif collection != blank %}
              {{ collection.title }}
            {% else %}
              Collection {{ i }}
            {% endif %}
          </h3>
        </a>
      {% endfor %}
    </div>
  </div>
</shop-collections-{{ ai_gen_id }}>

<script>
  (function() {
    class ShopCollections{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMobileScroll();
      }

      setupMobileScroll() {
        const grid = this.querySelector('.ai-shop-collections-grid-{{ ai_gen_id }}');
        if (!grid) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', function(e) {
          if (window.innerWidth > 749) return;
          isDown = true;
          grid.style.cursor = 'grabbing';
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', function() {
          isDown = false;
          grid.style.cursor = 'grab';
        });

        grid.addEventListener('mouseup', function() {
          isDown = false;
          grid.style.cursor = 'grab';
        });

        grid.addEventListener('mousemove', function(e) {
          if (!isDown) return;
          if (window.innerWidth > 749) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 2;
          grid.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('shop-collections-{{ ai_gen_id }}', ShopCollections{{ ai_gen_id }});
  })();
</script>

